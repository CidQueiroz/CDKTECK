# CDKTECK Command Center - Variáveis de Ambiente

# ====== URL DA API ======
# Desenvolvimento
NEXT_PUBLIC_API_URL=http://localhost:8000

# Produção (descomente quando deployar)
# NEXT_PUBLIC_API_URL=https://api.cdkteck.com

# ====== TIMEOUTS ======
NEXT_PUBLIC_API_TIMEOUT=10000

# ====== FEATURE FLAGS ======
NEXT_PUBLIC_FEATURE_ANALYTICS=true
NEXT_PUBLIC_FEATURE_NOTIFICATIONS=false
NEXT_PUBLIC_FEATURE_EXPORT=true

# ====== AUTENTICAÇÃO ======
# Chave para armazenar token JWT no localStorage
NEXT_PUBLIC_TOKEN_STORAGE_KEY=access_token

# ====== LOGGING ======
NEXT_PUBLIC_DEBUG_MODE=false
NEXT_PUBLIC_LOG_LEVEL=info

# ====== RATE LIMITING ======
NEXT_PUBLIC_API_RATE_LIMIT=100
NEXT_PUBLIC_API_RATE_LIMIT_WINDOW=60000

# ====== CACHE ======
NEXT_PUBLIC_CACHE_TTL=300000

# ====== SENTRY (Error Tracking) - OPCIONAL ======
# NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ====== ANALYTICS - OPCIONAL ======
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_SEGMENT_KEY=your-segment-key
